classDiagram
    class Owner {
        +name
        +available_time
        +preferences
        +pets
        +add_pet()
        +update_preferences()
        +view_schedule()
    }

    class Pet {
        +name
        +breed
        +age
        +special_needs
        +tasks
        +add_task()
        +update_info()
    }

    class Task {
        +task_name
        +duration
        +priority
        +completed
        +mark_complete()
        +edit_task()
    }

    class Scheduler {
        +task_list
        +daily_plan
        +generate_schedule()
        +sort_tasks()
        +display_schedule()
    }

    Owner "1" --> "1" Scheduler : uses
    Scheduler "1" --> "1" Owner : reads available_time
    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "0..*" Task : organizes
